{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@legal-ai-assistant/types": [
        "../../packages/types/src/index.ts"
      ],
      "@legal-ai-assistant/types/*": [
        "../../packages/types/src/*"
      ],
      "@legal-ai-assistant/db": [
        "../../packages/db/src/index.ts"
      ],
      "@legal-ai-assistant/db/*": [
        "../../packages/db/src/*"
      ],
      "@legal-ai-assistant/sandbox": [
        "../../packages/sandbox/src/index.ts"
      ],
      "@legal-ai-assistant/sandbox/*": [
        "../../packages/sandbox/src/*"
      ],
      "@legal-ai-assistant/claude-client": [
        "../../packages/claude-client/src/index.ts"
      ],
      "@legal-ai-assistant/claude-client/*": [
        "../../packages/claude-client/src/*"
      ],
      "@legal-ai-assistant/claude-tools": [
        "../../packages/claude-tools/src/index.ts"
      ],
      "@legal-ai-assistant/claude-tools/*": [
        "../../packages/claude-tools/src/*"
      ],
      "@legal-ai-assistant/embeddings": [
        "../../packages/embeddings/src/index.ts"
      ],
      "@legal-ai-assistant/embeddings/*": [
        "../../packages/embeddings/src/*"
      ],
      "@legal-ai-assistant/ocr": [
        "../../packages/ocr/src/index.ts"
      ],
      "@legal-ai-assistant/ocr/*": [
        "../../packages/ocr/src/*"
      ],
      "@legal-ai-assistant/stt": [
        "../../packages/stt/src/index.ts"
      ],
      "@legal-ai-assistant/stt/*": [
        "../../packages/stt/src/*"
      ],
      "@legal-ai-assistant/docx-export": [
        "../../packages/docx-export/src/index.ts"
      ],
      "@legal-ai-assistant/docx-export/*": [
        "../../packages/docx-export/src/*"
      ],
      "@legal-ai-assistant/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@legal-ai-assistant/ui/*": [
        "../../packages/ui/src/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "pages/**/*.tsx",
    ".next/types/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
