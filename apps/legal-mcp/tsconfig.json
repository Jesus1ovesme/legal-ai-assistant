{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "incremental": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "lib": ["ES2023"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
