# ============================================================================
# legal-ai-assistant — AI-помощник юриста (<APP_URL>)
# Скопируй в .env, заполни значения, chmod 600 .env
# ============================================================================

# ---- Public URL --------------------------------------------------------------
APP_URL=https://example.com
APP_PORT=3010
APP_HOST=127.0.0.1
NODE_ENV=production

# ---- PostgreSQL --------------------------------------------------------------
DATABASE_URL=postgresql://legal-ai-assistant:CHANGE_ME@127.0.0.1:5432/legal-ai-assistant_db

# ---- Auth -------------------------------------------------------------------
# 32+ байт случайных, для iron-session AES-256-GCM. Не использовать пример.
SESSION_PASSWORD=CHANGE_ME_TO_RANDOM_32_BYTES_BASE64URL_STRING_xxxxxxxx

# Секретный ключ для login-формы (используется в /api/auth/login). Дай юристу.
APP_ACCESS_KEY=CHANGE_ME_RANDOM_TOKEN

# Имя iron-session cookie. Term-server и web должны совпадать. По умолчанию — legal-ai-assistant_session.
SESSION_COOKIE_NAME=legal-ai-assistant_session

# Bootstrap пользователя (используется только при первом запуске scripts/bootstrap-user.ts)
BOOTSTRAP_EMAIL=user@example.com
BOOTSTRAP_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
BOOTSTRAP_DISPLAY_NAME=Юрист

# ---- Claude / Anthropic -----------------------------------------------------
# api | api+proxy | relay (relay в MVP — заглушка)
CLAUDE_TRANSPORT=api
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_DEFAULT_MODEL=claude-opus-4-7
CLAUDE_DEFAULT_EFFORT=max
CLAUDE_TIMEOUT_MS=120000
CLAUDE_MAX_TOKENS=8192

# Путь к claude CLI бинарнику (директория с версией; spawn найдёт claude через PATH=…/bin).
CLAUDE_BIN=/path/to/claude/cli/version

# Включается только при CLAUDE_TRANSPORT=api+proxy (обход геоблока через Xray на ${PROXY_HOST})
# Адрес SOCKS5-прокси (Xray/VPN-сервер) — настрой под свою инфраструктуру
PROXY_HOST=127.0.0.1
# Публичный IP сервера, на котором задеплоен legal-ai-assistant (DNS A-запись)
SERVER_IP=127.0.0.1
CLAUDE_OUTBOUND_PROXY=
RU_PROXY_URL=

# Slot для будущего OAuth-релея (в MVP не используется)
CLAUDE_RELAY_URL=
CLAUDE_RELAY_TOKEN=

# ---- Embeddings -------------------------------------------------------------
# e5-local | openai | yandex
EMBEDDING_PROVIDER=e5-local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
# Только для openai-провайдера:
OPENAI_API_KEY=

# ---- STT (Whisper) ----------------------------------------------------------
# openai-api | whisper-cpp
STT_PROVIDER=openai-api
# Если whisper-cpp — укажи путь к собранному бинарнику и модели:
WHISPER_CPP_BIN=/usr/local/bin/whisper-cli
WHISPER_CPP_MODEL=/path/to/.cache/whisper/ggml-base.bin

# ---- Web search (SearXNG self-host) -----------------------------------------
SEARXNG_URL=http://127.0.0.1:8888

# ---- File sandbox -----------------------------------------------------------
UPLOADS_ROOT=/path/to/legal-ai-assistant/uploads
MAX_FILE_SIZE_BYTES=52428800
MAX_FILES_PER_REQUEST=10

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# ---- Tools ------------------------------------------------------------------
# kad.arbitr.ru sidecar — Playwright headless, локально :7711
KAD_SIDECAR_URL=http://127.0.0.1:7711

# legal-mcp: Garant API (опционально, fallback на consultant.ru при отсутствии)
GARANT_API_TOKEN=

# ---- Term-server (PTY с claude TUI) -----------------------------------------
TERM_SERVER_PORT=3011

# ---- Бюджет (для UsageBar) --------------------------------------------------
BUDGET_DAY_USD=10
BUDGET_WEEK_USD=50
